[code]
  editor = zed --wait
[commit]
  gpgsign = true
[core]
  autocrlf = input
  pager = delta
[credential "https://github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
[diff]
  colorMoved = default
  tool = zed
[difftool "zed"]
  cmd = zed --wait --diff $LOCAL $REMOTE
[delta]
  navigate = true
[gpg]
  format = ssh
[interactive]
  diffFilter = delta --color-only
[merge]
  conflictstyle = diff3
  tool = zed
[mergetool]
  keepBackup = false
[mergetool "zed"]
  cmd = zed --wait $MERGED
[pager]
  difftool = true
[pull]
  rebase = true
[init]
  defaultBranch = main
[rerere]
  enabled = true
[tag]
  gpgsign = true
[user]
  email = 1085683+therockstorm@users.noreply.github.com
  name = Rocky Warren
  signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIINCFUtIiP7+XYUkuLHHbGlzDUi6Su51pppnV0YPw7qd id_ed25519 GitHub
[filter "lfs"]
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
# Work identity by remote, not directory — matches exactly what the employer
# bootstrap's configure-git would write (absolute path included), so it skips
# instead of dirtying this file through the ~/.gitconfig symlink. The include
# is silently ignored where ~/.gitconfig-clipboard doesn't exist.
[includeIf "hasconfig:remote.*.url:https://github.com/ClipboardHealth/**"]
  path = /Users/rocky/.gitconfig-clipboard
[includeIf "hasconfig:remote.*.url:git@github.com:ClipboardHealth/**"]
  path = /Users/rocky/.gitconfig-clipboard
# URL variants seen on real checkouts, which the canonical patterns above
# miss: embedded userinfo (https://user@github.com/…) and non-canonical
# org-name casing (matching is case-sensitive). Written so no remote matches
# twice — git applies every matching includeIf, and a double include would
# duplicate any multi-valued key the work overlay ever grows.
[includeIf "hasconfig:remote.*.url:https://*@github.com/ClipboardHealth/**"]
  path = /Users/rocky/.gitconfig-clipboard
[includeIf "hasconfig:remote.*.url:https://github.com/clipboard[Hh]ealth/**"]
  path = /Users/rocky/.gitconfig-clipboard
[includeIf "hasconfig:remote.*.url:https://github.com/Clipboardhealth/**"]
  path = /Users/rocky/.gitconfig-clipboard
[url "https://github.com/"]
  insteadOf = git@github.com:
