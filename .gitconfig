[code]
  editor = zed --wait
[commit]
  gpgsign = true
[core]
  autocrlf = input
  pager = delta
[credential "https://github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
[diff]
  colorMoved = default
  tool = zed
[difftool "zed"]
  cmd = zed --wait --diff $LOCAL $REMOTE
[delta]
  navigate = true
[gpg]
  format = ssh
[interactive]
  diffFilter = delta --color-only
[merge]
  conflictstyle = diff3
  tool = zed
[mergetool]
  keepBackup = false
[mergetool "zed"]
  cmd = zed --wait $MERGED
[pager]
  difftool = true
[pull]
  rebase = true
[init]
  defaultBranch = main
[rerere]
  enabled = true
[tag]
  gpgsign = true
[user]
  email = 1085683+therockstorm@users.noreply.github.com
  name = Rocky Warren
  signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIINCFUtIiP7+XYUkuLHHbGlzDUi6Su51pppnV0YPw7qd id_ed25519 GitHub
[filter "lfs"]
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[includeIf "gitdir:~/dev/c/"]
  path = ~/.gitconfig-clipboard
[coderabbit]
  machineId = cli/8a65971be4d34d20a0f6549a2aaf1679
[url "https://github.com/"]
  insteadOf = git@github.com:
